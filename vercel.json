{
  "version": 2,
  "routes": [
    {
      "src": "/api/auth/github",
      "dest": "/api/auth/github.ts"
    },
    {
      "src": "/api/auth/callback",
      "dest": "/api/auth/callback.ts"
    },
    {
      "src": "/api/sync",
      "dest": "/api/sync.ts"
    },
    {
      "src": "/api/repos",
      "dest": "/api/repos.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  }
}
